renv/library/
renv/local/
renv/cellar/
renv/staging/

# --- R session files ---
.Rhistory
.RData
.Rproj.user/

# --- Outputs / large intermediates (optional - adjust to taste) ---
results/
*.log

# --- OS / editor cruft ---
.DS_Store
*~
.vscode/
