# --- Data (controlled-access; never commit) ---
data/
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.gds
*.bed
*.bim
*.fam

# --- Credentials / secrets ---
.synapseConfig
*.pem
*token*
